# Single source of truth: put secrets here. Backends and Next.js load this file from the repo root.
#
# Database (PostgreSQL) — used by Prisma in http-backend / ws-backend.
#
# Supabase: copy the Postgres URI from the dashboard: "Connect" (project top) → Postgres.
# Do NOT paste the anon/publishable keys from the API Keys tab; those are for @supabase/supabase-js only.
#
# "Direct connection" (db.<project>.supabase.co:5432) is IPv6-only by default. If Prisma errors with
# P1001 / "Can't reach database server" on your Mac, switch to "Session pooler" in the same Connect UI
# (IPv4-friendly), then paste that full URI and add ?sslmode=require if not already present.
#
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# JWT Secret for authentication
JWT_SECRET="replace-with-a-long-random-secret"

# Environment
NODE_ENV="development"

# Next.js (optional — public-urls.ts has defaults)
# NEXT_PUBLIC_HTTP_URL="http://localhost:3001"
# NEXT_PUBLIC_WS_URL="ws://localhost:8080"
# NEXT_PUBLIC_ENABLE_LIVE_DEMO="false"
