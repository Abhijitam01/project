# Root `.env` — copy to `.env`. See README for Docker vs Supabase DATABASE_URL.

DATABASE_URL="postgresql://postgres:mysecretpassword@127.0.0.1:5433/drawr"
JWT_SECRET="replace-with-a-long-random-secret"
NODE_ENV="development"

# Browser calls the REST API on the Next.js origin (port 3000); Next rewrites to http-backend.
NEXT_PUBLIC_HTTP_URL="http://127.0.0.1:3000/api/backend"
NEXT_PUBLIC_WS_URL="ws://localhost:8080"
HTTP_BACKEND_INTERNAL_URL="http://127.0.0.1:3001"

CORS_ORIGINS="http://127.0.0.1:3000,http://localhost:3000"
JWT_EXPIRES_IN="7d"
DEMO_PASSWORD="demo12345"
