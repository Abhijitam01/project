# Copy repo root `.env.example` to `<repo>/.env` — do not maintain a separate `.env` in this folder.
#
# Runtime
NODE_ENV=production
PORT=3001
HTTP_PORT=3001

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Database (Prisma). Supabase: Connect → Postgres URI — not API Keys.
# If direct host fails (P1001), use Session pooler URI from the same Connect dialog.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Frontend URLs allowed by CORS (comma-separated)
CORS_ORIGINS=https://your-frontend.onrender.com
